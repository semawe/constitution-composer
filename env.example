# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Supabase project credentials (required)
# Create a free project at https://supabase.com, then find these in Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin emails (comma-separated) — who can access the /admin panel.
# Front-end gating only; the real barrier is the is_admin() SQL function + RLS.
# Keep this list in sync with supabase/migrations (is_admin function).
NEXT_PUBLIC_ADMIN_EMAILS=you@example.com

# Coaches offered for booking (optional — leave blank to hide the booking section).
# JSON array of { "name", "url" } — url is a public booking page (e.g. Google Calendar).
# NEXT_PUBLIC_COACHES=[{"name":"Jane","url":"https://calendar.app.google/xxxx"}]
NEXT_PUBLIC_COACHES=

# Umami analytics (optional — leave blank to disable)
# https://umami.is
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
